# ──────────────────────────────────────────────
# VerdantCare Medical Center — Environment Variables
# Copy this file to server/.env and fill in real values
# ──────────────────────────────────────────────

# Server
PORT=5000
NODE_ENV=development

# MongoDB
MONGODB_URI=mongodb://localhost:27017/verdantcare_db

# JWT Authentication
JWT_ACCESS_SECRET=change_me_access
JWT_REFRESH_SECRET=change_me_refresh
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# Client URL (CORS)
CLIENT_URL=http://localhost:5173

# Redis (optional — app works without it)
REDIS_HOST=localhost
REDIS_PORT=6379

# Cloudinary — File uploads (optional)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Twilio — SMS / Video (optional)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_API_KEY_SID=
TWILIO_API_KEY_SECRET=
TWILIO_PHONE_NUMBER=

# SMTP Email (optional)
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=noreply@verdantcare.com

# Stripe Payments (optional)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Razorpay Payments - UPI, Cards, NetBanking, Wallets (optional)
# Get keys from: https://dashboard.razorpay.com/app/keys
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# Google OAuth (optional)
GOOGLE_CLIENT_ID=

# Stripe Publishable Key (client — optional, for Stripe checkout)
VITE_STRIPE_PUBLISHABLE_KEY=

# Frontend URL (for email links)
FRONTEND_URL=http://localhost:5173
