# ──────────────────────────────────────
# VerdantCare Server Environment
# Copy this file to .env and fill in your values
# ──────────────────────────────────────

PORT=5000
NODE_ENV=production

# MongoDB Atlas connection string
# Format: mongodb+srv://<username>:<password>@<cluster>.mongodb.net/verdantcare
MONGODB_URI=

# JWT Secrets — generate strong random strings (use: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))")
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# Client URL (CORS) — your production frontend URLs, comma-separated
CLIENT_URL=https://your-domain.com

# Redis (optional — used for rate limiting and OTP caching)
REDIS_HOST=
REDIS_PORT=6379

# Cloudinary (optional – for image uploads)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Twilio (optional – for SMS)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_API_KEY_SID=
TWILIO_API_KEY_SECRET=
TWILIO_PHONE_NUMBER=

# Email / SMTP (Gmail)
# IMPORTANT: Generate an App Password from your Google Account
# Steps: Google Account → Security → 2-Step Verification → App Passwords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=noreply@verdantcare.com

# Frontend URL (for email links)
FRONTEND_URL=https://your-domain.com

# Google OAuth (optional – Sign in with Google)
GOOGLE_CLIENT_ID=

# Stripe Payments (optional)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Razorpay Payments (UPI, Cards, NetBanking, Wallets)
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
